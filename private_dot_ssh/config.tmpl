# ~/.ssh/config — managed by chezmoi

# ── Defaults for all hosts ───────────────────────────────────────────────────
Host *
    AddKeysToAgent yes
    UseKeychain yes
    IdentitiesOnly yes
    ServerAliveInterval 60
    ServerAliveCountMax 3

# ── GitHub (personal key) ────────────────────────────────────────────────────
Host github.com
    HostName github.com
    User git
    IdentityFile ~/.ssh/id_ed25519

{{ if eq .machine_type "work" -}}
