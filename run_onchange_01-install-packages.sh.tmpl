#!/bin/bash
# 01 — Install Homebrew + brew bundle (re-runs when any Brewfile changes)
# chezmoi: run_onchange
# Brewfile hash: {{ include "Brewfile" | sha256sum }}
# Brewfile.personal hash: {{ include "Brewfile.personal" | sha256sum }}
# Brewfile.work hash: {{ include "Brewfile.work" | sha256sum }}

set -uo pipefail

MACHINE_TYPE={{ .machine_type | quote }}
echo "── chezmoi run_onchange: installing packages (machine: $MACHINE_TYPE) ──"

# ── Install Homebrew if not present ──────────────────────────────────────────
if ! command -v brew &>/dev/null; then
  echo "→ Homebrew not found. Installing..."
  /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"

  if [[ -d "/opt/homebrew/bin" ]]; then
    eval "$(/opt/homebrew/bin/brew shellenv)"
  elif [[ -d "/usr/local/bin" ]]; then
    eval "$(/usr/local/bin/brew shellenv)"
  fi
else
  echo "→ Homebrew already installed."
fi

# ── Install shared packages ──────────────────────────────────────────────────
SOURCE_DIR={{ .chezmoi.sourceDir | quote }}

if [[ -f "$SOURCE_DIR/Brewfile" ]]; then
  echo "→ Installing shared packages..."
  brew bundle --file="$SOURCE_DIR/Brewfile" || echo "⚠ Some shared packages failed."
fi

# ── Install machine-specific packages ────────────────────────────────────────
MACHINE_BREWFILE="$SOURCE_DIR/Brewfile.$MACHINE_TYPE"

if [[ -f "$MACHINE_BREWFILE" ]]; then
  echo "→ Installing $MACHINE_TYPE-specific packages..."
  brew bundle --file="$MACHINE_BREWFILE" || echo "⚠ Some $MACHINE_TYPE packages failed."
else
  echo "⚠ No machine-specific Brewfile found at $MACHINE_BREWFILE — skipping."
fi

echo "── done ──"
