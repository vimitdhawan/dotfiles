[user]
	name = {{ .git_name }}
{{- if eq .machine_type "work" }}
	email = {{ .git_email_work }}
{{- else }}
	email = {{ .git_email_personal }}
{{- end }}

# ── Multi-account: directory-based email override ────────────────────────────
# Repos under ~/Work/ use work email, repos under ~/Personal/ use personal email
# This works on BOTH machines — clone work repos into ~/Work/, personal into ~/Personal/
[includeIf "gitdir:~/Work/"]
	path = ~/.config/git/work

[includeIf "gitdir:~/Personal/"]
	path = ~/.config/git/personal

[pull]
	rebase = false

[push]
	autoSetupRemote = true
	default = current

[init]
	defaultBranch = main

[core]
	editor = nvim
	pager = delta
	excludesFile = ~/.config/git/ignore

[interactive]
	diffFilter = delta --color-only

[delta]
	navigate = true
	side-by-side = true
	line-numbers = true
	syntax-theme = Dracula

[merge]
	conflictstyle = zdiff3

[diff]
	algorithm = histogram
	colorMoved = default

[fetch]
	prune = true

[rebase]
	autoSquash = true
	autoStash = true

[alias]
	s = status -sb
	l = log --oneline --graph --decorate -20
	la = log --oneline --graph --decorate --all
	co = checkout
	cb = checkout -b
	cm = commit -m
	ca = commit --amend --no-edit
	d = diff
	ds = diff --staged
	p = pull
	pf = push --force-with-lease
	stash-all = stash --include-untracked
	undo = reset --soft HEAD~1
	wip = "!git add -A && git commit -m 'wip'"
